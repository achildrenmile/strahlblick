# Synology deployment configuration
SYNOLOGY_HOST=your-synology-host
SYNOLOGY_USER=your-username
SYNOLOGY_PATH=/volume1/docker/strahlblick

# Site configuration
SITE_NAME=Strahlblick
SITE_DESCRIPTION=HF-Feldstärke & Sicherheitsabstands-Rechner

# Parent site branding (optional)
PARENT_SITE_NAME=OE Radio
PARENT_SITE_URL=https://oeradio.at
PARENT_SITE_LOGO=https://oeradio.at/wp-content/uploads/2024/05/cropped-OE-Radio-Logo-1.png

# Container configuration
CONTAINER_NAME=strahlblick
CONTAINER_PORT=3403

# Public URL for verification (optional)
PUBLIC_URL=https://strahlblick.oeradio.at
